# Storage backend: 'local' or 's3'
STORAGE_BACKEND=local

# Local mode: filesystem root (absolute path, or empty for repo root)
# STORAGE_ROOT=

# S3 mode -- ai-tutor-bench-deidentified (released bench bucket; transcripts +
# hybrid GT live here). Uncomment the block below:
# STORAGE_BACKEND=s3
# S3_BUCKET=ai-tutor-bench-deidentified
# S3_PREFIX=
# STORAGE_TRANSCRIPTS=source/step_up_benchmark.jsonl
# STORAGE_GROUND_TRUTH=synthetic/ground_truth_hybrid
# Swap transcripts to full corpus (~31K rows) when needed:
# STORAGE_TRANSCRIPTS=source/step_up.jsonl

# S3 mode -- kylel-alexisr-edu (internal bucket; screenshots + raw)
# S3_BUCKET=kylel-alexisr-edu
# S3_PREFIX=
# STORAGE_SCREENSHOTS=deidentified/screenshots

# Other path overrides
# STORAGE_ANNOTATOR_RESULTS=results/annotator
# STORAGE_BENCHMARK_RESULTS=results/benchmark

# API keys
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Logging
# LOG_LEVEL=INFO     # DEBUG, INFO, WARNING, ERROR
# LOG_FILE=1         # set to 0 to disable per-run file handler at logs/{version}/run.log
